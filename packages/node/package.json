{
  "name": "runspec-node",
  "version": "0.11.1",
  "description": "Node/TypeScript language pack for runspec",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "runspec": "./bin/runspec.js"
  },
  "scripts": {
    "build": "tsc && cp src/runspec.toml dist/runspec.toml",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": ["runspec", "cli", "arguments", "agents", "mcp"],
  "author": "Jason Finestone",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JasonFinestone/runspec"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "jest": "^30.4.2",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "smol-toml": "^1.0.0"
  }
}
